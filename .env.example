# silly-code environment configuration
# Copy to .env and edit

# Provider selection (set by bin/sillyx, sillyt, sillye — usually not manual)
# CLAUDE_CODE_USE_OPENAI=1
# CLAUDE_CODE_USE_COPILOT=1

# Data directory
# SILLY_CODE_DATA=~/.silly-code

# Force recovery CLI mode (simple readline, no Ink TUI)
# CLAUDE_CODE_FORCE_RECOVERY_CLI=1
