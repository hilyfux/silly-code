#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"
source "$ROOT_DIR/bin/silly-common.sh"

DATA_DIR="${SILLY_CODE_DATA:-$HOME/.silly-code}"
mkdir -p "$DATA_DIR"

check_provider() {
  local name="$1" token_file="$2"
  # Check both new (-auth.json) and legacy (-oauth.json) filenames
  local alt_file="${token_file/-oauth.json/-auth.json}"
  if [ -f "$DATA_DIR/$token_file" ] || [ -f "$DATA_DIR/$alt_file" ]; then
    ok "$name: logged in"
    return 0
  else
    warn "$name: not logged in"
    return 1
  fi
}

check_claude() {
  # Claude stores tokens in ~/.claude/.credentials.json (managed by TUI)
  local cred="$HOME/.claude/.credentials.json"
  if [ -f "$cred" ] || [ -f "$DATA_DIR/claude-oauth.json" ]; then
    ok "Claude  (sillye): logged in"
    return 0
  else
    warn "Claude  (sillye): not logged in"
    return 1
  fi
}

case "${1:-}" in
  status)
    echo ""
    echo -e "  ${B}silly-code${N} — Multi-Provider AI Coding Assistant"
    echo ""
    check_provider "Codex   (sillyx)" "codex-oauth.json" || true
    check_provider "Copilot (sillyt)" "copilot-oauth.json" || true
    check_claude || true
    echo ""
    exit 0
    ;;
  login)
    PROVIDER="${2:-}"
    case "$PROVIDER" in
      codex)
        node "$ROOT_DIR/pipeline/login.mjs" codex
        ;;
      copilot)
        node "$ROOT_DIR/pipeline/login.mjs" copilot
        ;;
      claude)
        info "Launching Silly Code — use /login inside the TUI to sign in to claude.ai"
        PATCHED="$ROOT_DIR/pipeline/build/cli-patched.js"
        if [ ! -f "$PATCHED" ]; then
          info "Building patched binary (first run)..."
          node "$ROOT_DIR/pipeline/patch.cjs" || { err "Patch build failed"; exit 1; }
        fi
        exec node "$PATCHED"
        ;;
      "")
        echo "Usage: silly login <provider>"
        echo "Providers: codex, copilot, claude"
        ;;
      *)
        err "Unknown provider: $PROVIDER"
        exit 1
        ;;
    esac
    exit 0
    ;;
  logout)
    PROVIDER="${2:-}"
    case "$PROVIDER" in
      codex)   rm -f "$DATA_DIR/codex-oauth.json" "$DATA_DIR/codex-auth.json";     ok "Codex tokens removed" ;;
      copilot) rm -f "$DATA_DIR/copilot-oauth.json" "$DATA_DIR/copilot-auth.json"; ok "Copilot tokens removed" ;;
      claude)  rm -f "$DATA_DIR/claude-oauth.json";  ok "Claude tokens removed" ;;
      "") err "Usage: silly logout <codex|copilot|claude>"; exit 1 ;;
      *) err "Unknown provider: $PROVIDER"; exit 1 ;;
    esac
    exit 0
    ;;
  models)
    echo ""
    echo -e "  ${B}Available Models${N}"
    echo ""
    echo "  Codex (sillyx):"
    echo "    gpt-5.4              1M context (272k practical)"
    echo "    gpt-5.4-mini         Fast mini model"
    echo "    gpt-5.3-codex        Industry-leading coding"
    echo ""
    echo "  Copilot (sillyt):"
    echo "    claude-opus-4-6      128k context (Copilot cap)"
    echo "    claude-sonnet-4      200k context"
    echo "    o3                   200k context"
    echo ""
    echo "  Claude (sillye):"
    echo "    claude-opus-4-6      1M context"
    echo "    claude-sonnet-4-6    1M context"
    echo "    claude-haiku-4-5     200k context"
    echo ""
    exit 0
    ;;
  doctor)
    MISSING=false
    echo ""
    echo -e "  ${B}silly-code doctor${N}"
    echo ""

    # Version / commit
    VERSION=$(cd "$ROOT_DIR" && git describe --tags --always 2>/dev/null || echo "unknown")
    COMMIT=$(cd "$ROOT_DIR" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    ok "Version: $VERSION (commit $COMMIT)"
    ok "Platform: $(uname -s) $(uname -m)"

    # Runtime
    MISSING=false
    if command -v node >/dev/null 2>&1; then
      NODE_VER=$(node -e "console.log(process.versions.node.split('.')[0])")
      if [ "$NODE_VER" -ge 20 ] 2>/dev/null; then
        ok "Node: $(node --version)"
      else
        err "Node: $(node --version) (need >= 20)"; MISSING=true
      fi
    else
      err "Node: not found"; MISSING=true
    fi
    command -v git >/dev/null 2>&1 && ok "Git: $(git --version | head -1)" || warn "Git: not found (optional)"
    command -v rg >/dev/null 2>&1 && ok "ripgrep: $(rg --version | head -1)" || warn "ripgrep: not found (file search will be slow)"
    PATCHED="$ROOT_DIR/pipeline/build/cli-patched.js"
    [ -f "$PATCHED" ] && ok "Patched binary: found" || { err "Patched binary: missing (run: node pipeline/patch.cjs)"; MISSING=true; }

    # Provider auth
    echo ""
    check_provider "Codex   (sillyx)" "codex-oauth.json" || true
    check_provider "Copilot (sillyt)" "copilot-oauth.json" || true
    check_claude || true

    # Defaults
    echo ""
    ok "Mode: patched binary (upstream + silly-code patches)"

    # AutoDream / memory
    MEMDIR="$HOME/.claude/projects"
    if [ -d "$MEMDIR" ]; then
      MCOUNT=$(find "$MEMDIR" -name "*.md" -path "*/memory/*" 2>/dev/null | wc -l | tr -d ' ')
      ok "Memory files: $MCOUNT across projects"
    else
      info "Memory: no projects yet"
    fi
    ok "AutoDream: enabled (24h + 5 sessions gate)"

    # Computer use
    echo ""
    if [ "$(uname -s)" = "Darwin" ]; then
      [ -f "$ROOT_DIR/runtime/mac_helper.py" ] && ok "Computer use: available (macOS)" || warn "Computer use: mac_helper.py missing"
    else
      info "Computer use: not available (macOS only)"
    fi

    # Fallback
    AUTHED=0
    { [ -f "$DATA_DIR/codex-auth.json" ] || [ -f "$DATA_DIR/codex-oauth.json" ]; } && AUTHED=$((AUTHED+1))
    { [ -f "$DATA_DIR/copilot-auth.json" ] || [ -f "$DATA_DIR/copilot-oauth.json" ]; } && AUTHED=$((AUTHED+1))
    [ -f "$HOME/.claude/.credentials.json" ] && AUTHED=$((AUTHED+1))
    if [ "$AUTHED" -ge 2 ]; then
      ok "Provider fallback: active ($AUTHED providers)"
    elif [ "$AUTHED" -eq 1 ]; then
      info "Provider fallback: unavailable (only 1 provider authenticated)"
    else
      warn "Provider fallback: no providers authenticated"
    fi

    echo ""
    [ "$MISSING" = true ] && { err "Some checks failed. Fix the issues above."; exit 1; }
    ok "Ready for use."
    echo ""
    exit 0
    ;;
  update)
    echo ""
    echo -e "  ${B}silly-code update${N}"
    echo ""

    # Read deps.json for version info
    DEPS_JSON="$ROOT_DIR/deps.json"
    if [ ! -f "$DEPS_JSON" ]; then
      err "deps.json not found at $ROOT_DIR"
      exit 1
    fi

    UPDATE_MODE="${2:-check}"

    # ── Check dependencies ──
    info "Checking dependencies..."

    # Node
    if command -v node >/dev/null 2>&1; then
      ok "Node: $(node --version)"
    else
      warn "Node: not installed (required)"
    fi

    # ripgrep
    WANT_RG=$(node -e "console.log(require('$DEPS_JSON').deps.ripgrep.version)")
    if command -v rg >/dev/null 2>&1; then
      CUR_RG=$(rg --version | head -1 | awk '{print $2}')
      ok "ripgrep: $CUR_RG (want >= $WANT_RG)"
    else
      warn "ripgrep: not installed (want >= $WANT_RG)"
    fi

    # Git
    if command -v git >/dev/null 2>&1; then
      ok "Git: $(git --version | awk '{print $3}')"
    else
      warn "Git: not installed"
    fi

    # ── Check self-update (silly-code repo) ──
    echo ""
    info "Checking for silly-code updates..."
    LOCAL_COMMIT=$(cd "$ROOT_DIR" && git rev-parse HEAD 2>/dev/null || echo "unknown")
    LOCAL_SHORT=$(cd "$ROOT_DIR" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")

    REMOTE_COMMIT=$(curl -fsSL -H "Accept: application/vnd.github.v3+json" \
      "https://api.github.com/repos/hilyfux/silly-code/commits/main" 2>/dev/null \
      | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{console.log(JSON.parse(d).sha||'unknown')}catch{console.log('unknown')}})" 2>/dev/null \
      || echo "unknown")

    if [ "$REMOTE_COMMIT" = "unknown" ]; then
      warn "Could not check remote (offline or rate limited)"
    elif [ "$LOCAL_COMMIT" = "$REMOTE_COMMIT" ]; then
      ok "silly-code: up to date ($LOCAL_SHORT)"
    else
      REMOTE_SHORT="${REMOTE_COMMIT:0:7}"
      warn "silly-code: update available (local $LOCAL_SHORT → remote $REMOTE_SHORT)"
      if [ "$UPDATE_MODE" = "apply" ]; then
        info "Pulling latest..."
        cd "$ROOT_DIR"
        if git pull --ff-only origin main 2>/dev/null; then
          ok "Updated to $(git rev-parse --short HEAD)"
          info "Rebuilding patched binary..."
          node "$ROOT_DIR/pipeline/patch.cjs" || warn "Patch rebuild failed"
          ok "Binary updated"
        else
          warn "Pull failed — run 'silly update apply' again or reinstall"
        fi
      else
        echo ""
        echo "  Run 'silly update apply' to update"
      fi
    fi

    # ── npm deps freshness ──
    echo ""
    if [ -f "$ROOT_DIR/bun.lock" ]; then
      ok "Lock file: bun.lock present"
    else
      warn "Lock file: missing (run bun install)"
    fi

    # Save check timestamp
    mkdir -p "$DATA_DIR"
    echo "{\"lastChecked\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"}" > "$DATA_DIR/deps-state.json"

    echo ""
    exit 0
    ;;
  uninstall)
    echo ""
    if [ -f "$ROOT_DIR/uninstall.sh" ]; then
      exec bash "$ROOT_DIR/uninstall.sh"
    else
      err "uninstall.sh not found. Re-install first or run:"
      echo "  curl -fsSL https://raw.githubusercontent.com/hilyfux/silly-code/main/uninstall.sh | bash"
      exit 1
    fi
    ;;
  help|--help|-h)
    echo ""
    echo -e "  ${B}silly-code${N} — Multi-Provider AI Coding Assistant"
    echo ""
    echo "  Management:"
    echo "    silly status          Show provider auth status"
    echo "    silly login <prov>    Login to a provider"
    echo "    silly logout <prov>   Remove stored tokens"
    echo "    silly models          List available models"
    echo "    silly doctor          Check prerequisites"
    echo "    silly update          Check for updates"
    echo "    silly update apply    Apply available updates"
    echo "    silly uninstall       Remove silly-code completely"
    echo ""
    echo "  Launch:"
    echo "    sillyx                Start with Codex"
    echo "    sillyt                Start with Copilot"
    echo "    sillye                Start with Claude"
    echo ""
    exit 0
    ;;
  "")
    echo ""
    echo -e "  ${B}silly-code${N} — Multi-Provider AI Coding Assistant"
    echo ""
    check_provider "Codex   (sillyx)" "codex-oauth.json" || true
    check_provider "Copilot (sillyt)" "copilot-oauth.json" || true
    check_claude || true
    echo ""
    echo "  Get started:"
    echo "    silly login codex     Login to ChatGPT Pro / Codex"
    echo "    silly login copilot   Login to GitHub Copilot"
    echo "    silly login claude    Login to Claude Pro/Max"
    echo ""
    echo "  Then launch: sillyx / sillyt / sillye"
    echo ""
    exit 0
    ;;
  *)
    err "Unknown command: $1"
    echo "Run 'silly help' for usage."
    exit 1
    ;;
esac
