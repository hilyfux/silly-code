#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export CALLER_DIR="$(pwd -W 2>/dev/null || pwd)"
cd "$ROOT_DIR"
source "$ROOT_DIR/bin/silly-common.sh"

# Provider: Claude native (firstParty) — default, no env flag needed

export SILLY_CODE_DATA="${SILLY_CODE_DATA:-$HOME/.silly-code}"
mkdir -p "$SILLY_CODE_DATA"

if [ ! -f "$SILLY_CODE_DATA/claude-oauth.json" ] && [ ! -f "$HOME/.claude/.credentials.json" ]; then
  echo ""
  echo "  sillye — Claude"
  echo ""
  info "Not logged in. The TUI will open — type /login to sign in."
  echo ""
  # Claude login happens inside the TUI via /login command.
  # Unlike Codex/Copilot, there's no standalone CLI login flow,
  # so we proceed directly to the TUI.
fi

# ── Ensure patched binary exists ────────────────────────────
PATCHED="$ROOT_DIR/pipeline/build/cli-patched.js"
if [ ! -f "$PATCHED" ]; then
  info "Building patched binary (first run)..."
  node "$ROOT_DIR/pipeline/patch.cjs" || { err "Patch build failed"; exit 1; }
fi

cd "$CALLER_DIR"
exec node "$PATCHED" "$@"
