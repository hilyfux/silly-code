#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export CALLER_DIR="$(pwd -W 2>/dev/null || pwd)"
cd "$ROOT_DIR"
source "$ROOT_DIR/bin/silly-common.sh"

# Provider: Claude native (firstParty) — default, no env flag needed

export SILLY_CODE_DATA="${SILLY_CODE_DATA:-$HOME/.silly-code}"
mkdir -p "$SILLY_CODE_DATA"

if [ ! -f "$SILLY_CODE_DATA/claude-oauth.json" ]; then
  echo ""
  echo "  sillye — Claude"
  echo ""
  info "Not logged in. Launching TUI for login..."
  echo ""
  # Claude login happens inside the TUI via /login command
fi

# Model defaults
export ANTHROPIC_MODEL="${ANTHROPIC_MODEL:-claude-opus-4-6}"
export ANTHROPIC_SMALL_FAST_MODEL="${ANTHROPIC_SMALL_FAST_MODEL:-claude-haiku-4-5}"

# Disable non-essential traffic
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

if [[ "${CLAUDE_CODE_FORCE_RECOVERY_CLI:-0}" == "1" ]]; then
  exec bun --env-file=.env ./src/localRecoveryCli.ts "$@"
fi

exec bun --env-file=.env "${SILLY_FEATURES[@]}" ./src/entrypoints/cli.tsx "${SILLY_DEFAULT_ARGS[@]}" "$@"
