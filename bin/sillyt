#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export CALLER_DIR="$(pwd -W 2>/dev/null || pwd)"
cd "$ROOT_DIR"
source "$ROOT_DIR/bin/silly-common.sh"

# Provider: GitHub Copilot
export CLAUDE_CODE_USE_COPILOT=1

export SILLY_CODE_DATA="${SILLY_CODE_DATA:-$HOME/.silly-code}"
mkdir -p "$SILLY_CODE_DATA"

if [ ! -f "$SILLY_CODE_DATA/copilot-oauth.json" ]; then
  echo ""
  echo "  sillyt — GitHub Copilot"
  echo ""
  info "Not logged in. Starting login now..."
  echo ""
  "$ROOT_DIR/bin/silly" login copilot
  # Re-check after login
  if [ ! -f "$SILLY_CODE_DATA/copilot-oauth.json" ]; then
    echo ""
    warn "Login was cancelled. Run 'sillyt' again when ready."
    exit 1
  fi
fi

export ANTHROPIC_MODEL="${ANTHROPIC_MODEL:-claude-sonnet-4}"
export ANTHROPIC_SMALL_FAST_MODEL="${ANTHROPIC_SMALL_FAST_MODEL:-claude-haiku-4-5}"
export CLAUDE_CODE_AUTO_COMPACT_WINDOW="${CLAUDE_CODE_AUTO_COMPACT_WINDOW:-167000}"
export DISABLE_NON_ESSENTIAL_MODEL_CALLS=1
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

if [[ "${CLAUDE_CODE_FORCE_RECOVERY_CLI:-0}" == "1" ]]; then
  exec bun --env-file=.env ./src/localRecoveryCli.ts ${SILLY_DEFAULT_ARGS[@]+"${SILLY_DEFAULT_ARGS[@]}"} "$@"
fi

exec bun --env-file=.env ${SILLY_FEATURES[@]+"${SILLY_FEATURES[@]}"} ./src/entrypoints/cli.tsx ${SILLY_DEFAULT_ARGS[@]+"${SILLY_DEFAULT_ARGS[@]}"} "$@"
