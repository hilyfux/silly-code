#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export CALLER_DIR="$(pwd -W 2>/dev/null || pwd)"
cd "$ROOT_DIR"
source "$ROOT_DIR/bin/silly-common.sh"

# Provider: OpenAI Codex
export CLAUDE_CODE_USE_OPENAI=1

export SILLY_CODE_DATA="${SILLY_CODE_DATA:-$HOME/.silly-code}"
mkdir -p "$SILLY_CODE_DATA"

if [ ! -f "$SILLY_CODE_DATA/codex-oauth.json" ]; then
  echo ""
  echo "  sillyx — OpenAI Codex"
  echo ""
  info "Not logged in. Starting login now..."
  echo ""
  "$ROOT_DIR/bin/silly" login codex
  if [ ! -f "$SILLY_CODE_DATA/codex-oauth.json" ]; then
    echo ""
    warn "Login was cancelled. Run 'sillyx' again when ready."
    exit 1
  fi
fi

# Model defaults
export ANTHROPIC_MODEL="${ANTHROPIC_MODEL:-gpt-5.4}"
export ANTHROPIC_SMALL_FAST_MODEL="${ANTHROPIC_SMALL_FAST_MODEL:-gpt-5.4-mini}"

# Context window: gpt-5.4 practical limit 272k, minus output reserve (33k)
export CLAUDE_CODE_AUTO_COMPACT_WINDOW="${CLAUDE_CODE_AUTO_COMPACT_WINDOW:-239000}"

# Disable non-essential traffic
export DISABLE_NON_ESSENTIAL_MODEL_CALLS=1
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

if [[ "${CLAUDE_CODE_FORCE_RECOVERY_CLI:-0}" == "1" ]]; then
  exec bun --env-file=.env ./src/localRecoveryCli.ts "$@"
fi

exec bun --env-file=.env "${SILLY_FEATURES[@]}" ./src/entrypoints/cli.tsx "$@"
