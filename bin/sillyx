#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export CALLER_DIR="$(pwd -W 2>/dev/null || pwd)"
cd "$ROOT_DIR"
source "$ROOT_DIR/bin/silly-common.sh"

# Provider: OpenAI Codex
export CLAUDE_CODE_USE_OPENAI=1

export SILLY_CODE_DATA="${SILLY_CODE_DATA:-$HOME/.silly-code}"
mkdir -p "$SILLY_CODE_DATA"

if [ ! -f "$SILLY_CODE_DATA/codex-auth.json" ] && [ ! -f "$SILLY_CODE_DATA/codex-oauth.json" ]; then
  echo ""
  echo "  sillyx — OpenAI Codex"
  echo ""
  info "Not logged in. Starting login now..."
  echo ""
  "$ROOT_DIR/bin/silly" login codex
  if [ ! -f "$SILLY_CODE_DATA/codex-auth.json" ] && [ ! -f "$SILLY_CODE_DATA/codex-oauth.json" ]; then
    echo ""
    warn "Login was cancelled. Run 'sillyx' again when ready."
    exit 1
  fi
fi

# ── Ensure patched binary exists ────────────────────────────
PATCHED="$ROOT_DIR/pipeline/build/cli-patched.js"
if [ ! -f "$PATCHED" ]; then
  info "Building patched binary (first run)..."
  node "$ROOT_DIR/pipeline/patch.cjs" || { err "Patch build failed"; exit 1; }
fi

cd "$CALLER_DIR"
exec node "$PATCHED" "$@"
