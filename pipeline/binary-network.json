    "getAPIProviderForStatsig": "Zr",
    "isClaudeAISubscriber": "m7",
    "isDebugToStdErr": "US",
    "createStderrLogger": "pV6",
    "getProxyFetchOptions": "F16",
    "isFirstPartyAnthropicBaseUrl": "lH",
    "modelAwareProviderResolver": "BX",
    "mantleOverrideCheck": "u08"
  },

  "functions": {
    "getAPIProvider": {
      "minified_name": "dq",
      "offset_approx": 2287347,
      "landmark": "return B6(process.env.CLAUDE_CODE_USE_BEDROCK)?\"bedrock\"",
      "provider_chain": [
        { "env": "CLAUDE_CODE_USE_OPENAI",   "returns": "openai",      "status": "INJECTED",  "patch_id": "10" },
        { "env": "CLAUDE_CODE_USE_COPILOT",  "returns": "copilot",     "status": "INJECTED",  "patch_id": "10" },
        { "env": "CLAUDE_CODE_USE_BEDROCK",  "returns": "bedrock",     "status": "ORIGINAL" },
        { "env": "CLAUDE_CODE_USE_FOUNDRY",  "returns": "foundry",     "status": "ORIGINAL" },
        { "check": "anthropicAws",           "returns": "anthropicAws","status": "ORIGINAL" },
        { "check": "mantle via u08()",       "returns": "mantle",      "status": "ORIGINAL" },
        { "env": "CLAUDE_CODE_USE_VERTEX",   "returns": "vertex",      "status": "ORIGINAL" },
        { "default": true,                   "returns": "firstParty",  "status": "ORIGINAL" }
      ]
    },

    "getAnthropicClient": {
      "minified_name": "anonymous (near N('[API:auth] OAuth token check starting'))",
      "offset_approx": 3440000,
      "landmark": "\"[API:auth] OAuth token check starting\"",
      "entry_pattern": "N(\"[API:auth] OAuth token check starting\"),await WA()",
      "provider_variable": "P",
      "resolver_call": "P=BX(_)",
      "config_variable": "M",
      "config_contains": ["defaultHeaders", "maxRetries", "timeout", "fetchOptions"],
      "constructor_pattern": "new D(k) or new D(Z) where D = dynamically imported Anthropic SDK",
      "branches": [
        { "condition": "P===\"openai\"",     "action": "CODEX_FETCH_ADAPTER",   "status": "TODO",     "patch_id": "11" },
        { "condition": "P===\"copilot\"",    "action": "COPILOT_FETCH_ADAPTER", "status": "TODO",     "patch_id": "12" },
        { "condition": "P===\"bedrock\"",    "action": "new AnthropicBedrock()", "status": "ORIGINAL" },
        { "condition": "P===\"foundry\"",    "action": "new AnthropicFoundry()", "status": "ORIGINAL" },
        { "condition": "P===\"anthropicAws\"","action": "AWS variant",           "status": "ORIGINAL" },
        { "condition": "P===\"mantle\"",     "action": "Mantle variant",         "status": "ORIGINAL" },
        { "condition": "P===\"vertex\"",     "action": "new AnthropicVertex()",  "status": "ORIGINAL" },
        { "condition": "default",            "action": "new Anthropic(M)",       "status": "ORIGINAL" }
      ]
    },

    "getAPIProviderForStatsig": {
      "minified_name": "Zr",
      "description": "Wraps dq() for analytics/statsig reporting",
      "adjacent_to": "getAPIProvider"
    }
  },

